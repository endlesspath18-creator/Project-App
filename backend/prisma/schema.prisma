generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER
  PROVIDER
  ADMIN
}

enum ServiceStatus {
  AVAILABLE
  BUSY
  DISABLED
}

enum BookingStatus {
  DRAFT
  REQUESTED
  PENDING
  ACCEPTED
  PROVIDER_ACCEPTED
  PAYMENT_PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  REJECTED
  PAYMENT_FAILED
  EXPIRED
  REFUNDED
}

model User {
  id           String   @id @default(uuid())
  fullName     String
  email        String   @unique
  phone        String?  @unique
  passwordHash String?
  role         Role     @default(USER)
  isRoleSet    Boolean  @default(true)
  googleId     String?  @unique
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  hasPaidPublishingFee Boolean  @default(false)
  canPublishService    Boolean  @default(false)
  isVerified           Boolean  @default(false)
  
  providerProfile ProviderProfile?
  services     Service[]
  bookings     Booking[]      @relation("UserBookings")
  jobs         Booking[]      @relation("ProviderBookings")
  reviewsAsUser     Review[]       @relation("UserReviews")
  reviewsAsProvider Review[]       @relation("ProviderReviews")
  transactions PaymentTransaction[]
  notifications Notification[]
  refreshTokens RefreshToken[]
}

model AdminPaymentConfig {
  id            String   @id @default(uuid())
  upiId         String?
  accountName   String?
  bankName      String?
  accountNumber String?
  ifscCode      String?
  updatedAt     DateTime @updatedAt
}

model PaymentTransaction {
  id               String   @id @default(uuid())
  userId           String
  type             String   // e.g., "BOOKING", "PROVIDER_ACTIVATION"
  amount           Float
  commissionAmount Float    @default(0.0)
  providerAmount   Float    @default(0.0)
  status           String   // e.g., "PENDING", "SUCCESS", "FAILED"
  paymentId        String?  @unique // Gateway ID (Unique to prevent replay)
  orderId          String?  @unique // Gateway Order ID
  gatewayResponse  Json?    // Full response from gateway for auditing
  bookingId        String?
  createdAt        DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  booking Booking? @relation(fields: [bookingId], references: [id])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  action    String   // e.g., "UPDATE_PAYOUT_SETTINGS", "MANUAL_UNLOCK"
  details   String?  @db.Text
  ipAddress String?
  createdAt DateTime @default(now())
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ProviderProfile {
  id              String  @id @default(uuid())
  userId          String  @unique
  businessName    String
  bio             String?
  experienceYears Int?    @default(0)
  rating          Float   @default(0.0)
  totalJobs       Int     @default(0)
  isOnline        Boolean @default(true)
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Service {
  id              String        @id @default(uuid())
  providerId      String
  title           String
  category        String
  description     String
  price           Float
  durationMinutes Int
  status          ServiceStatus @default(AVAILABLE)
  isActive        Boolean       @default(true)
  images          String[]      @default([])
  rating          Float         @default(0.0)
  totalJobs       Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  provider User      @relation(fields: [providerId], references: [id], onDelete: Cascade)
  bookings Booking[]
}

model Booking {
  id            String        @id @default(uuid())
  userId        String
  providerId    String
  serviceId     String
  status        BookingStatus @default(REQUESTED)
  dateTime      DateTime      // Unified name as 'dateTime'
  slot          String?       // Display slot like "10:00 AM - 11:00 AM"
  address       String
  notes         String?
  amount        Float         // Renamed from totalAmount to amount
  durationMinutes Int         @default(60) // Store duration at booking time
  paymentMethod String        @default("COD") // COD or ONLINE
  paymentStatus String        @default("PENDING")
  paymentId     String?       // Razorpay Payment ID
  orderId       String?       // Razorpay Order ID
  holdExpiresAt DateTime?     // Slot lock expiry
  idempotencyKey String?      @unique
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user     User    @relation("UserBookings", fields: [userId], references: [id])
  provider User    @relation("ProviderBookings", fields: [providerId], references: [id])
  service  Service @relation(fields: [serviceId], references: [id])
  
  reviews  Review[]
  events   BookingEvent[]
  transactions PaymentTransaction[]

  @@unique([providerId, dateTime])
}

model BookingEvent {
  id         String   @id @default(uuid())
  bookingId  String
  fromStatus String
  toStatus   String
  actorId    String   // User ID of the person who triggered the change
  meta       Json?
  createdAt  DateTime @default(now())

  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  type      String?  // e.g., "BOOKING_UPDATE", "SYSTEM"
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Review {
  id         String   @id @default(uuid())
  bookingId  String   @unique
  userId     String
  providerId String
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())

  booking  Booking @relation(fields: [bookingId], references: [id])
  user     User    @relation("UserReviews", fields: [userId], references: [id])
  provider User    @relation("ProviderReviews", fields: [providerId], references: [id])
}
